---
import clsx from 'clsx'
import type { HTMLAttributes } from 'astro/types'

type EyebrowAttributes = HTMLAttributes<'p'> & HTMLAttributes<'span'> & HTMLAttributes<'div'>

interface Props extends Omit<EyebrowAttributes, 'class' | 'style'> {
  as?: keyof HTMLElementTagNameMap
}

const { as: Component = 'p', ...htmlProps } = Astro.props

const className = clsx(
  'font-mono text-[0.72rem] leading-snug font-medium tracking-[0.18em] uppercase',
  'text-neutral-500 dark:text-neutral-400'
)
---

<Component class={className} {...htmlProps}>
  <slot />
</Component>
