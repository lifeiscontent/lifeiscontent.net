---
import Layout from '@layouts/layout.astro'
import ButtonLink from '@components/ui/button-link.astro'
import Section from '@components/layouts/section.astro'
import Stack from '@components/layouts/stack.astro'
import Heading from '@components/ui/heading.astro'
import Text from '@components/ui/text.astro'
import CalloutPanel from '@components/ui/callout-panel.astro'

const title = 'Page not found'
const description = "This page doesn't exist or has moved."
---

<Layout title={title} description={description}>
  <Section paddingX="sm" paddingY="xl" paddingYAtSm="2xl">
    <Stack direction="row" justify="center" width="full">
      <CalloutPanel>
        <Stack as="main" direction="column" width="full" gap="lg">
          <Heading level={2} size="3xl" sizeAtSm="4xl" weight="bold" tone="accent"> 404 </Heading>
          <Stack direction="column" gap="sm">
            <Heading level={1} size="2xl" sizeAtSm="3xl" weight="bold"> Page not found </Heading>
            <Text tone="muted">
              This page doesn't exist or has moved. Try one of the links below.
            </Text>
          </Stack>
          <Stack
            direction="column"
            directionAtSm="row"
            gap="sm"
            align="start"
            width="full"
            widthAtSm="auto"
          >
            <ButtonLink href="/" variant="primary" size="md" width="responsive">
              Go home
            </ButtonLink>
            <ButtonLink href="/blog-postings" variant="secondary" size="md" width="responsive">
              Read the blog
            </ButtonLink>
          </Stack>
        </Stack>
      </CalloutPanel>
    </Stack>
  </Section>
</Layout>
